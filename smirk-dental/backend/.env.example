# ═══════════════════════════════════════════
# Smirk Dental — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smirk_dental?retryWrites=true&w=majority

# Frontend URL (optional) — added to CORS allowlist (single origin)
FRONTEND_URL=https://www.your-frontend-domain.com

# Extra allowed browser origins (comma-separated, no spaces). Use on Render for
# custom domain + Vercel URL, e.g.:
# ALLOWED_ORIGINS=https://www.smirkdental.com,https://smirkdental.com,https://smirk-clinic.vercel.app
ALLOWED_ORIGINS=

# ── Optional: Email notifications via Nodemailer ──
# SMTP credentials (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Clinic email (receives booking notifications)
CLINIC_EMAIL=mehak

# ── Optional: Google Places API (for real reviews) ──
# GOOGLE_PLACES_API_KEY=AIza...
# GOOGLE_PLACE_ID=ChIJ...

# ── WhatsApp Cloud API (webhook + outbound) ──
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# WHATSAPP_API_URL=https://graph.facebook.com/v19.0
# VERIFY_TOKEN=
# Doctor WhatsApp wa_id (digits only, same format as message.from)
DOCTOR_WA_ID=91XXXXXXXXXX
# Optional: verify webhook payloads (Meta App Secret)
# WHATSAPP_APP_SECRET=
# Optional: maps link sent from patient "Location" button
# CLINIC_MAPS_URL=https://www.google.com/maps?q=LAT,LNG&z=18

# Optional: WhatsApp template names (create & approve in Meta Business Manager)
# Body params order: see services/reminderJobs.js
# WHATSAPP_TEMPLATE_REMINDER_24H=
# WHATSAPP_TEMPLATE_REMINDER_1H=
# WHATSAPP_TEMPLATE_LANG=en
# WHATSAPP_TEMPLATE_CHECKUP=
# Anniversary check-up reminders (daily 9:00 IST) — body params: patient name, last visit date, clinic name
# WHATSAPP_TEMPLATE_CHECKUP_MONTHLY=
# WHATSAPP_TEMPLATE_CHECKUP_QUARTERLY=
# WHATSAPP_TEMPLATE_CHECKUP_6MONTH=

# Prescription / visit updates (doctor → patient) — REQUIRED for patients outside 24h window
# Create in Meta Business Manager → WhatsApp → Message templates (Utility category)
#
# 1) WHATSAPP_TEMPLATE_PRESCRIPTION — photo prescriptions (IMAGE header)
#    Header: Image (variable)
#    Body: Hi {{1}}, {{2}} has shared your prescription.\nVisit date: {{3}}\nProcedure: {{4}}
#
# 2) WHATSAPP_TEMPLATE_PRESCRIPTION_DOC — PDF prescriptions (DOCUMENT header, optional)
#    Header: Document (variable)
#    Body: same as above
#
# 3) WHATSAPP_TEMPLATE_VISIT_UPDATE — procedure-only visits, no file (optional)
#    Body only: Hi {{1}}, {{2}} has updated your visit record.\nVisit date: {{3}}\nProcedure: {{4}}
#
# WHATSAPP_TEMPLATE_PRESCRIPTION=smirk_prescription
# WHATSAPP_TEMPLATE_PRESCRIPTION_DOC=smirk_prescription_doc
# WHATSAPP_TEMPLATE_VISIT_UPDATE=smirk_visit_update

# Google Gemini — prescription OCR / procedure + date extraction (doctor WhatsApp flow)
# GEMINI_API_KEY=
