# ═══════════════════════════════════════════
# Smirk Dental — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smirk_dental?retryWrites=true&w=majority

# Frontend URL (for CORS) — your deployed frontend domain
FRONTEND_URL=https://your-frontend-domain.com

# ── Optional: Email notifications via Nodemailer ──
# SMTP credentials (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Clinic email (receives booking notifications)
CLINIC_EMAIL=mehak@smirkdental.in

# ── Optional: Google Places API (for real reviews) ──
# GOOGLE_PLACES_API_KEY=AIza...
# GOOGLE_PLACE_ID=ChIJ...
